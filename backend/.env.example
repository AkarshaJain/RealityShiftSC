# Copy this file to ".env" and fill in values.
# The .env file is git-ignored — never commit real secrets.

# Server
PORT=3000
NODE_ENV=development

# Demo mode: when true, endpoints return labeled mock data so Lens work
# is never blocked. Flip to "false" once Layer 3b is wired to real logic.
DEMO_MODE=true

# Optional paid providers — all off by default. The free path does not need these.
# OPENAI_API_KEY=
# OPENFOODFACTS_USER_AGENT=ShelfSense/0.1 (contact@example.com)
