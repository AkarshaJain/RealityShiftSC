# Copy this file to ".env" and fill in values.
# The .env file is git-ignored — never commit real secrets.

# Server
PORT=3000
NODE_ENV=development

# Demo mode: when true, endpoints return labeled mock data so Lens work
# is never blocked. Flip to "false" once Layer 3b is wired to real logic.
DEMO_MODE=true

# Optional paid providers — all off by default. The free path does not need these.
# OPENAI_API_KEY=
# OPENFOODFACTS_USER_AGENT=ShelfSense/0.1 (contact@example.com)

# Google Cloud Vision API key — enables real OCR of `image_base64` payloads on
# POST /api/analyze-label. Create one:
#   1. https://console.cloud.google.com/ → create / pick a project
#   2. Enable "Cloud Vision API" (APIs & Services → Library)
#   3. APIs & Services → Credentials → Create credentials → API key
#   4. Restrict the key to "Cloud Vision API" (Security tab)
# The first 1000 text-detection requests/month are free.
# GOOGLE_VISION_API_KEY=
